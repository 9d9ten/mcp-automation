{
  "name": "@9d9/mcp-automation",
  "version": "0.1.0",
  "description": "Automation utilities for Model Context Protocol (MCP) workflows",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "keywords": ["mcp", "model-context-protocol", "automation", "workflow", "9d9"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/9d9ten/mcp-automation" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
